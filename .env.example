DATABASE_URL=postgresql://twave_01:twave_01password@localhost:5432/qa_db
PG_HOST=localhost
PG_PORT=5432
PG_USER=twave_01
PG_PASSWORD=twave_01password
PG_DATABASE=qa_db
PG_SSL=false
DB_MODE=postgres

# =========================
# API/App config placeholders
# =========================
SOLR_URL=http://localhost:8983
SOLR_CORE_NAME=mycore

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=abcd1234
REDIS_DB=0

OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_MODEL=gpt-oss:120b
CHAT_MODEL_NAME=gpt-oss:120b
CHAT_TITLE_MODEL_NAME=gpt-oss:120b
CHAT_KEYWORD_MODEL_NAME=gpt-oss:120b

RAG_INDEX_LANGUAGE=multi

FRONTEND_HOST=localhost
FRONTEND_PORT=7001
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
WEB_PORT=7001
API_PORT=8080
PUBLIC_BASE_URL=http://localhost:7001

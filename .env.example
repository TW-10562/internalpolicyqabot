PUBLIC_API_BASE_URL=
RAG_BACKEND_HOST=127.0.0.1
RAG_BACKEND_PORT=8010
RAG_BACKEND_URL=http://localhost:8010
RAG_SERVICE_URL=http://localhost:8010
RAG_FORCE_GPU_ONLY=0
FAQ_CACHE_API_URL=http://localhost:8001

# UI local dev overrides (used by ui-2/vite)
VITE_PORT=7001
VITE_API_BASE_URL=http://localhost:8080


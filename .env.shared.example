# ═══════════════════════════════════════════════════════════════════
# Shared Environment Variables for hrbot (API + RAG + Database Services)
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env in the api/ and rag/ directories
# Use these ENV vars to configure ports and endpoints for shared DGX server

# Application Ports (non-conflicting defaults on shared DGX server)

# Node.js Backend API (api/src/main.ts)
# Default: 8080 (changed from 9090 because prometheus container uses 9090)
# Configurable to avoid conflicts
PORT=<set-at-deploy>
BACKEND_HOST=<set-at-deploy>
BACKEND_PORT=<set-at-deploy>

# FastAPI RAG Service (rag/main.py)
# ⚠️ IMPORTANT: Default 8000 is in use on DGX - uses 8010 instead
RAG_HOST=<set-at-deploy>
RAG_PORT=<set-at-deploy>

# ─────────────────────────────────────────────────────────────────────
# DATABASE & CACHE SERVICES
# ─────────────────────────────────────────────────────────────────────
# IMPORTANT: These values differ based on deployment context!
#
# For LOCAL DEVELOPMENT (pnpm dev, python main.py):
#   → Use localhost with MAPPED host ports
#   → PG_HOST=localhost, PG_PORT=55432 (mapped from 5432)
#   → REDIS_HOST=localhost, REDIS_PORT=16379 (mapped from 6379)
#
# For DOCKER CONTAINER deployment (inside docker compose network):
#   → Use SERVICE NAMES with CONTAINER ports
#   → PG_HOST=postgres, PG_PORT=5432 (container ports)
#   → REDIS_HOST=redis, REDIS_PORT=6379 (container ports)
#
# DEFAULT BELOW: Configured for LOCAL DEVELOPMENT

# PostgreSQL (local: localhost:55432, docker: postgres:5432)
PG_HOST=<set-at-deploy>
PG_PORT=<set-at-deploy>
PG_DATABASE=<set-at-deploy>
PG_USER=<set-at-deploy>
PG_PASSWORD=<set-at-deploy>

# Redis (local: localhost:16379, docker: redis:6379)
REDIS_HOST=<set-at-deploy>
REDIS_PORT=<set-at-deploy>
REDIS_PASSWORD=<set-at-deploy>
REDIS_DB=<set-at-deploy>
# Apache Solr (same for both: 8983)
SOLR_HOST=<set-at-deploy>
SOLR_PORT=<set-at-deploy>
SOLR_URL=<set-at-deploy>
SOLR_CORE=<set-at-deploy>

# ─────────────────────────────────────────────────────────────────────
# LLM GATEWAY / AI SERVICES
# ─────────────────────────────────────────────────────────────────────

# OpenAI-Compatible LLM Gateway (apisix or similar at port 9080)
LLM_BASE_URL=<set-at-deploy>
LLM_API_KEY=<set-at-deploy>
LLM_MODEL=<set-at-deploy>

# For remote deployments, update these to:
# LLM_BASE_URL=http://172.30.140.148:9080/v1
# LLM_API_KEY=your-api-key-here

# ─────────────────────────────────────────────────────────────────────
# CROSS-SERVICE URLs (used by services to communicate with each other)
# ─────────────────────────────────────────────────────────────────────
# IMPORTANT: These values differ based on deployment context!
#
# For LOCAL DEVELOPMENT (pnpm dev, python main.py):
#   → Use localhost with actual ports
#   → RAG_BACKEND_URL=http://localhost:8010
#
# For DOCKER Container deployment (inside docker compose):
#   → Use SERVICE NAMES (they resolve via internal DNS)
#   → RAG_BACKEND_URL=http://rag:8010
#
# DEFAULT BELOW: Configured for LOCAL DEVELOPMENT

# RAG Backend Service URL (used by Node API to call RAG endpoints)
RAG_BACKEND_HOST=<set-at-deploy>
RAG_BACKEND_PORT=<set-at-deploy>
RAG_BASE_URL=<set-at-deploy>

# Node API Base URL (used by RAG and frontend)
API_BASE_URL=<set-at-deploy>
API_HOST=<set-at-deploy>
API_PORT=<set-at-deploy>

# FAQ Cache API (faq_database service)
FAQ_CACHE_API_URL=<set-at-deploy>
FAQ_CACHE_HOST=<set-at-deploy>
FAQ_CACHE_PORT=<set-at-deploy>

# ─────────────────────────────────────────────────────────────────────
# FRONTEND/UI CONFIGURATION
# ─────────────────────────────────────────────────────────────────────

FRONTEND_HOST=<set-at-deploy>
FRONTEND_PORT=<set-at-deploy>

# CORS Origins (comma-separated list of allowed origins)
# Update this for your deployment
ALLOWED_ORIGINS=<set-at-deploy>

# ─────────────────────────────────────────────────────────────────────
# AZURE AD / AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────

AZURE_TENANT_ID=<set-at-deploy>
AZURE_CLIENT_ID=<set-at-deploy>
AZURE_CLIENT_SECRET=<set-at-deploy>
AZURE_REDIRECT_URI=<set-at-deploy>

# ─────────────────────────────────────────────────────────────────────
# APPLICATION MODE
# ─────────────────────────────────────────────────────────────────────

APP_MODE=<set-at-deploy>
RAG_FORCE_GPU_ONLY=<set-at-deploy>

{
  "name": "api",
  "version": "1.0.0",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsnd -r tsconfig-paths/register --respawn src/main.ts",
    "worker": "cross-env NODE_ENV=development tsnd -r tsconfig-paths/register --respawn src/queue/worker.ts",
    "dev:all": "run-p dev worker",
    "lint": "npx eslint src/** --fix",
    "test:minimal": "ts-node-dev --transpile-only -r tsconfig-paths/register --exit-child --no-deps scripts/test_language_history_notifications.ts",
    "test:moderation": "ts-node-dev --transpile-only -r tsconfig-paths/register --exit-child --no-deps scripts/test_moderation_gate.ts",
    "bench:rag": "node scripts/benchmark_rag.js",
    "bench:rag:load": "node scripts/load_rag_profiles.js",
    "test:rag:pipeline": "ts-node-dev --transpile-only -r tsconfig-paths/register --exit-child --no-deps scripts/test_rag_pipeline_regression.ts",
    "eval:rag:excel": "node scripts/evaluate_rag_excel.js",
    "eval:rag:report": "node scripts/evaluate_rag_report.js",
    "eval:rag:core": "node scripts/evaluate_rag_core.js",
    "test:rag": "ts-node-dev --transpile-only -r tsconfig-paths/register --exit-child scripts/test_rag_gate.ts",
    "verify:storage": "ts-node-dev --transpile-only -r tsconfig-paths/register --exit-child src/tools/verifyStorage.ts",
    "backfill:files": "ts-node-dev --transpile-only -r tsconfig-paths/register --exit-child src/tools/backfillFilesFromDisk.ts",
    "backfill:rag:hybrid": "ts-node-dev --transpile-only -r tsconfig-paths/register --exit-child src/tools/backfillHybridCollectionFromSolr.ts",
    "reindex:solr": "ts-node-dev --transpile-only -r tsconfig-paths/register --exit-child src/tools/reindexSolr.ts",
    "aviary:sync-deps": "node scripts/sync_aviary_optional_deps.js",
    "aviary:check-deps": "node scripts/check_aviary_linkage.js",
    "aviary:check-deps:strict": "node scripts/check_aviary_linkage.js --strict",
    "aviary:check-core": "node scripts/check_aviary_linkage.js --profile=core",
    "aviary:check-core:strict": "node scripts/check_aviary_linkage.js --profile=core --strict",
    "aviary:install-core": "node scripts/install_aviary_deps.js --profile=core",
    "aviary:install-all": "node scripts/install_aviary_deps.js --profile=all",
    "eval:rag:gate": "node scripts/evaluate_rag_core.js --enforce-gate 1"
  },

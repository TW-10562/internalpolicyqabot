# Old-way team profile:
# - Code runs on local machine (api/ui-2/rag)
# - Shared infra runs on DGX
#
# DGX network endpoints used by this profile:
# - Postgres: <DGX_IP>:5433 (expobot-postgres-1 / qa_db)
# - Redis:    <DGX_IP>:6380
# - Solr:     <DGX_IP>:8984

NODE_ENV=development
PORT=8080
DB_MODE=postgres

# Local API -> DGX Postgres proxy
DATABASE_URL=postgresql://twave_01:twave_01password@172.30.140.163:5433/qa_db
PG_HOST=172.30.140.163
PG_PORT=5433
PG_USER=twave_01
PG_PASSWORD=twave_01password
PG_DATABASE=qa_db
PG_SSL=false

# Local API -> DGX Redis/Solr
REDIS_HOST=172.30.140.163
REDIS_PORT=6380
REDIS_PASSWORD=abcd1234
REDIS_DB=0

SOLR_URL=http://172.30.140.163:8984
SOLR_CORE_NAME=mycore

# LLM endpoint on DGX
OLLAMA_BASE_URL=http://172.30.140.163:11435
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TITLE_MODEL=gpt-oss:20b
OLLAMA_TRANSLATION_MODEL=gpt-oss:20b

# In old-way, rag + faq_cache usually run locally
RAG_BACKEND_URL=http://127.0.0.1:8010
RAG_BACKEND_HOST=127.0.0.1
RAG_BACKEND_PORT=8010
FAQ_CACHE_API_URL=http://127.0.0.1:8001

# Mount DGX docs path to local WSL and point to mount path
# e.g. bash api/scripts/setup_dgx_wsl.sh <dgx_user> <dgx_ip> /srv/tbot/storage/docs /mnt/dgx_docs
DOCS_ROOT=/mnt/dgx_docs

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-refresh

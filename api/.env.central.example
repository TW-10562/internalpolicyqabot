# Centralized deployment profile for API clients
# Prefilled for current DGX: 172.30.140.163

NODE_ENV=development
PORT=8080
DB_MODE=postgres
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TITLE_MODEL=gpt-oss:20b
OLLAMA_TRANSLATION_MODEL=gpt-oss:20b
TRIAGE_ROUTING_MODEL_NAME=gpt-oss:20b
TRIAGE_ROUTING_TIMEOUT_MS=18000
TRIAGE_ROUTING_ATTEMPTS=2
OLLAMA_BASE_URL=http://172.30.140.163:11435
CHAT_PROCESS_TIMEOUT_MS=180000

# Shared Postgres (central)
DATABASE_URL=postgresql://twave_01:twave_01password@172.30.140.163:5433/qa_db
PG_HOST=172.30.140.163
PG_PORT=5433
PG_USER=twave_01
PG_PASSWORD=twave_01password
PG_DATABASE=qa_db
PG_SSL=false

# Shared Redis (central)
REDIS_HOST=172.30.140.163
REDIS_PORT=6379
REDIS_PASSWORD=abcd1234
REDIS_DB=0

# Shared Solr + RAG (central)
SOLR_URL=http://172.30.140.163:8983
SOLR_CORE_NAME=mycore
RAG_BACKEND_URL=http://172.30.140.163:8010
RAG_BACKEND_HOST=172.30.140.163
RAG_BACKEND_PORT=8010
# FAQ cache currently listens on 127.0.0.1 on DGX.
# Keep localhost for API running on DGX; expose/change this for remote client APIs.
FAQ_CACHE_API_URL=http://127.0.0.1:8001

# RAG latency tuning (recommended defaults)
RAG_ASYNC_CHAT_TITLE=1
RAG_TRANSLATED_QUERY_BLEND=0
RAG_DUAL_LANGUAGE_RETRIEVAL_EN=0
RAG_QUERY_TRANSLATION_FALLBACK=1
RAG_SOLR_TIMEOUT_MS=8000
RAG_MAX_OUTPUT_TOKENS=420
RAG_CONTEXT_MAX_DOCS=2
RAG_RAW_NORMALIZE_MAX_CHARS=8000
RAG_FINAL_LANGUAGE_AUTOTRANSLATE=0
RAG_STREAMING=1
RAG_STREAM_DB_FLUSH_MS=120
RAG_RETRIEVAL_CACHE=1
RAG_RETRIEVAL_CACHE_TTL_SEC=1800
RAG_SOLR_ROWS=3
RAG_INTENT_SCAN_MAX_CHARS=12000
RAG_FORCE_GPU_ONLY=0
APP_CACHE_SCHEMA_VERSION=v1
RAG_ANSWER_CACHE_SCHEMA_VERSION=v1
RAG_CACHE_MIN_ANSWER_CHARS=96
RAG_CACHE_MIN_ANSWER_LINES=2
RAG_CACHE_REJECT_WEAK_HOWTO=1

# If API runs in local WSL and DGX is the storage server:
# 1) mount DGX docs into WSL (e.g. /mnt/dgx_docs)
# 2) set DOCS_ROOT to that mount path
# DOCS_ROOT=/mnt/dgx_docs

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-refresh

# RAG reliability guardrails (deterministic-first defaults)
RAG_LOW_CONFIDENCE_THRESHOLD=10
RAG_CONFIDENCE_MEDIUM=10
RAG_CONFIDENCE_HIGH=25
RAG_LEXICAL_STRICT_FIRST=1
RAG_LOW_EVIDENCE_GATE_ENABLED=1
RAG_MIN_CONFIDENCE_TO_ANSWER=10
RAG_MIN_TOP_TERM_HITS_TO_ANSWER=1
RAG_FAST_HOWTO_MIN_ACTION_STEPS=2
RAG_FAST_HOWTO_MIN_ACTION_RATIO=0.5
RAG_FAST_HOWTO_MAX_LEGAL_STYLE_RATIO=0.34
RAG_FAST_HOWTO_DETAIL_MIN_STEPS_JA=4
RAG_FAST_HOWTO_DETAIL_MIN_STEPS_EN=5
RAG_FAST_HOWTO_DETAIL_MAX_STEPS=8
RAG_FAST_HOWTO_DETAIL_MIN_CHARS_JA=220
RAG_FAST_HOWTO_DETAIL_MIN_CHARS_EN=280
RAG_FAST_HOWTO_EN_TRANSLATE_FALLBACK=1
RAG_FAST_HOWTO_EN_TRANSLATE_TIMEOUT_MS=12000
RAG_FAST_HOWTO_EN_TRANSLATE_RETRIES=0
RAG_ALLOW_GENERIC_RESCUE_FOR_HOWTO=0
TRANSLATION_STREAM_FIRST=1
TRANSLATION_MAX_TOKENS=640
TRANSLATION_RETRY_BACKOFF_MS=300
TRANSLATION_MIN_JA_RATIO=0.45
TRANSLATION_MAX_JA_RATIO_FOR_EN=0.08
TRANSLATE_ON_DEMAND_TIMEOUT_MS=30000
TRANSLATE_ON_DEMAND_SKIP_FINALIZE=1
TRANSLATE_ON_DEMAND_FAIL_OPEN=1
TRANSLATE_ON_DEMAND_ALLOW_LOCAL_MOCK=0
TRANSLATE_ON_DEMAND_SECOND_PASS=0
RAG_CONTEXT_MAX_CHUNKS=4
RAG_CONTEXT_MAX_CHUNKS_PER_SOURCE=1

# FAQ generation from organic query logs
FAQ_MIN_COUNT_DEFAULT=1
FAQ_INCLUDE_NON_USER_ROLES=1
FAQ_EXCLUDED_ROLE_CODES=
FAQ_STRICT_REQUIRE_RAG=1
FAQ_STRICT_REQUIRE_SOURCES=1
FAQ_RELAXED_MIN_COUNT=1

# Optional low-confidence retrieval assists (keep disabled by default)
RAG_QUERY_TRANSLATION_FOR_RETRIEVAL_ENABLED=0
RAG_INTENT_RECONSTRUCTION_ENABLED=0
RAG_LLM_QUERY_EXPANSION_ENABLED=0
RAG_QUERY_REPAIR_ENABLED=0
RAG_HYDE_ENABLED=0
RAG_LLM_RERANK_ENABLED=0

# Hybrid/vector tuning
RAG_VECTOR_RETRIEVAL_ENABLED=1
RAG_VECTOR_RETRIEVAL_TRIGGER_CONFIDENCE=10
RAG_VECTOR_RETRIEVAL_MAX_TERM_HITS=1
RAG_HYBRID_SOLR_WEIGHT=0.7
RAG_HYBRID_VECTOR_WEIGHT=0.3
RAG_SEMANTIC_VECTOR_ONLY=0
RAG_SEMANTIC_BM25_ONLY=0
RAG_SEMANTIC_VECTOR_WEIGHT=0.5
RAG_SEMANTIC_BM25_WEIGHT=0.5

# Evaluation gate thresholds
RAG_EVAL_ENFORCE_GATE=1
RAG_EVAL_MIN_HIT_AT_K=0.55
RAG_EVAL_MIN_GROUNDED_RATE=0.70
RAG_EVAL_MIN_SOURCE_TERM_OK_RATE=0.65
RAG_EVAL_MIN_REFUSAL_PRECISION=0.60
RAG_EVAL_MAX_AVG_LATENCY_MS=30000
